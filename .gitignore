# ─────────────────────────────────────────
resultados.txt
*.txt

# ─────────────────────────────────────────
# OS files
# ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────
# IDEs
# ─────────────────────────────────────────
.idea/
.vscode/
*.suo
*.user

# ─────────────────────────────────────────
# Temporary files
# ─────────────────────────────────────────
*.tmp
*.bak
*.swp
*.log
